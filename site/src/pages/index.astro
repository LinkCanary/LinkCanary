      <div class="hero-cta">
        <a href="https://github.com/LinkCanary/LinkCanary" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">Start monitoring free →</a>
        <a href="#demo" class="btn btn-ghost btn-lg">Watch it work</a>
      </div>
      <div class="microcopy">
        <span><span class="check">✓</span> <b>50 checks free forever</b></span>
        <span><span class="check">✓</span> <b>No credit card</b></span>
        <span><span class="check">✓</span> <b>2-minute setup</b></span>
      </div>
    </div>

    <div class="hero-visual reveal">
      <div class="speech" aria-hidden="true">chirp! found a dead one 🐤</div>
      <img class="mascot" src="data:image/png;base64," alt="LinkCanary mascot, a cheerful yellow canary" />
      <div class="monitor" role="img" aria-label="Live monitoring dashboard preview">
        <div class="bar">
          <span class="traf" style="background:#FF5F57"></span>
          <span class="traf" style="background:#FEBC2E"></span>
          <span class="traf" style="background:#28C840"></span>
          <span class="title">linkcanary · acme.com</span>
          <span class="live"><span class="dot"></span>LIVE</span>
        </div>
        <div class="rows">
          <div class="mrow"><span class="url">acme.com/</span><span class="ms">184ms</span><span class="badge ok">200</span></div>
          <div class="mrow"><span class="url">acme.com/pricing</span><span class="ms">142ms</span><span class="badge ok">200</span></div>
          <div class="mrow"><span class="url">acme.com/docs/api</span><span class="ms">096ms</span><span class="badge ok">200</span></div>
          <div class="mrow alert"><span class="url">acme.com/blog/2019-launch</span><span class="ms">-</span><span class="badge bad">404</span></div>
        </div>
        <div class="foot"><span class="dot" style="background:#F5C518;animation:none"></span> Alert sent → <span style="color:var(--text)">#eng-alerts</span> · 0.8s ago</div>
