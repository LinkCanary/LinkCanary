      <span>© 2026 LinkCanary. Made with care &amp; a watchful eye.</span>
      <span class="mono">www.linkcanary.io · status: <span style="color:var(--green)">● operational</span></span>
    </div>
  </div>
</footer>

<script is:inline>
(function(){
  var rm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // nav shadow on scroll
  var nav = document.getElementById('nav');
  window.addEventListener('scroll', function(){ nav.classList.toggle('scrolled', window.scrollY > 8); }, {passive:true});

  // mobile menu
  var mb = document.getElementById('menuBtn'), nm = document.getElementById('navMobile');
  if(mb){ mb.addEventListener('click', function(){ nm.classList.toggle('open'); });
    nm.querySelectorAll('a').forEach(function(a){ a.addEventListener('click', function(){ nm.classList.remove('open'); }); }); }

  // duplicate ticker for seamless loop
  var tk = document.getElementById('ticker');
  if(tk){ tk.innerHTML += tk.innerHTML; }

  // reveal on scroll
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target);} });
  }, {threshold:.12});
  document.querySelectorAll('.reveal').forEach(function(el){ io.observe(el); });

  // count-up stats
  function animateCount(el){
    var raw = el.getAttribute('data-count'); if(!raw) return;
    var target = parseFloat(raw), dec = raw.indexOf('.')>-1?1:0, start=null, dur=1500;
    function setTxt(v){
      var txt = dec ? v.toFixed(1) : Math.round(v).toLocaleString();
      el.childNodes.forEach(function(n){ if(n.nodeType===3) n.textContent = txt; });
    }
    function step(ts){ if(!start)start=ts; var p=Math.min((ts-start)/dur,1);
      var e = 1-Math.pow(1-p,3);
      setTxt(target*e);
      if(p<1) requestAnimationFrame(step); else setTxt(target);
    }
    requestAnimationFrame(step);
  }
  var sio = new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting){ if(!rm) animateCount(e.target); sio.unobserve(e.target);} });
  }, {threshold:.5});
  document.querySelectorAll('.stat .num[data-count]').forEach(function(el){ sio.observe(el); });

  // pricing toggle
  var tg = document.getElementById('toggle');
  if(tg){ tg.querySelectorAll('button').forEach(function(b){ b.addEventListener('click', function(){
    tg.querySelectorAll('button').forEach(function(x){x.classList.remove('active');}); b.classList.add('active');
    var p=b.getAttribute('data-p');
    document.querySelectorAll('.plan .price').forEach(function(pr){
      var val=pr.getAttribute('data-'+p); if(!val)return;
      var small = pr.getAttribute('data-mo')==='$0' ? '' : (p==='yr'?'<small>/mo</small>':'<small>/mo</small>');
      pr.innerHTML = val + small;
    });
  }); }); }

  // ── live terminal ──
  var term = document.getElementById('term');
  if(term){
    var paths = ['/', '/pricing', '/features', '/docs/api', '/blog', '/changelog', '/login', '/about', '/contact', '/status'];
    var i = 0, lines = [], MAX = 13;
    function ts(){ var d=new Date(); return d.toTimeString().slice(0,8); }
    function rand(a,b){ return Math.floor(Math.random()*(b-a))+a; }
    function render(){
      term.innerHTML = lines.join('') + '<span class="ln"><span class="t">'+ts()+'</span> canary watching<span class="cursor"></span></span>';
      term.scrollTop = term.scrollHeight;
    }
    function push(html){ lines.push('<div class="ln">'+html+'</div>'); if(lines.length>MAX) lines.shift(); }
    function tick(){
      var p = paths[i % paths.length]; i++;
      var broken = (i % 7 === 0);
      var ms = rand(72, 260);
      if(broken){
        push('<span class="t">'+ts()+'</span> <span class="m">GET</span> acme.com'+p+'  <span class="bad">404 NOT FOUND</span>  <span class="bad">✗ broken link</span>');
        setTimeout(function(){ push('<span class="t">'+ts()+'</span> <span class="al">⚠ ALERT</span> <span class="d">sent → #eng-alerts (Slack), ops@acme.com · screenshot attached</span>'); render(); }, 480);
      } else {
        push('<span class="t">'+ts()+'</span> <span class="m">GET</span> acme.com'+p+'  <span class="ok">200 OK</span>  <span class="d">'+ms+'ms</span> <span class="ok">✓</span>');
      }
      render();
    }
    // seed a few
    push('<span class="d">$ linkcanary watch --target acme.com --interval 30s</span>');
    push('<span class="d">▸ crawling sitemap… 142 links found · watching from 5 regions</span>');
    render();
    if(!rm){ var loop=setInterval(tick, 1400); tick(); }
    else { tick(); tick(); tick(); }
  }
})();
</script>
</body>
</html>
