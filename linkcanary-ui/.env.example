# Copy to .env and adjust. Used by docker-compose for the prod-like stack.

# --- Postgres (compose service credentials) ---
POSTGRES_USER=linkcanary
POSTGRES_PASSWORD=linkcanary
POSTGRES_DB=linkcanary

# --- Application (LINKCANARY_ prefix maps to Settings fields) ---
# Async SQLAlchemy URL; the sync driver (psycopg) is derived automatically.
LINKCANARY_DATABASE_URL=postgresql+asyncpg://linkcanary:linkcanary@postgres:5432/linkcanary

# Use Redis-backed Celery instead of in-process threads.
LINKCANARY_USE_CELERY=true
LINKCANARY_CELERY_BROKER_URL=redis://redis:6379/0
LINKCANARY_CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Report storage ---
# "local" (default, filesystem) or "s3" (S3 / Cloudflare R2).
LINKCANARY_STORAGE_BACKEND=local
# For Cloudflare R2, set STORAGE_BACKEND=s3 and fill these:
# LINKCANARY_S3_BUCKET=linkcanary-reports
# LINKCANARY_S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# LINKCANARY_S3_REGION=auto
# LINKCANARY_S3_ACCESS_KEY_ID=...
# LINKCANARY_S3_SECRET_ACCESS_KEY=...
# LINKCANARY_S3_PREFIX=crawls/
